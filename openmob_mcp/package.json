{
  "name": "openmob-mcp",
  "version": "0.0.8",
  "description": "MCP server for OpenMob - mobile device automation via AI agents",
  "type": "module",
  "main": "build/app/index.js",
  "bin": {
    "openmob-mcp": "build/app/index.js"
  },
  "files": [
    "build/**/*.js",
    "build/**/*.d.ts"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "bundle": "tsc && npx esbuild build/app/index.js --bundle --platform=node --target=node20 --format=cjs --outfile=dist/openmob-mcp-bundle.cjs",
    "dev": "tsx src/app/index.ts",
    "start": "node build/app/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0"
  }
}
